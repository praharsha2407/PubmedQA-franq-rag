# --- secrets: never commit ---
.env
*.pem
*.key

# --- environments / caches ---
.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/

# --- data & models (large, regenerable) ---
data/
models/
*.faiss
*.npy

# --- pipeline outputs (regenerable). advanced_answers.jsonl is the run
#     checkpoint; it lives on disk and in archive/checkpoints, not in git ---
outputs/
outputs_*/
*.jsonl.tmp

# --- logs (a single full run's log exceeds 100MB) ---
logs/
logs_*.out
logs_*.err
*.log

# --- local backups / archives (large tarballs) ---
archive/
backups/
*.tar.gz

# --- slurm bookkeeping ---
.full_jobid
.smoke_jobid
.strict_jobid
nettest.sh
scratch/
